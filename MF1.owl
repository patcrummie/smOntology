###  http://www.semanticweb.org/pat_c/ontologies/2026/5/untitled-ontology-12#hasQuantity
:hasQuantity rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf owl:topObjectProperty .


###  http://www.semanticweb.org/pat_c/ontologies/2026/5/untitled-ontology-12#hasTankType
:hasTankType rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf owl:topObjectProperty ;
             rdfs:domain :Tank ;
             rdfs:range :TankType .


###  http://www.semanticweb.org/pat_c/ontologies/2026/5/untitled-ontology-12#hasUnitOfMeasurement
:hasUnitOfMeasurement rdf:type owl:ObjectProperty ;
                      rdfs:domain :Measures ;
                      rdfs:range :UnitOfMeasurement .


###  http://www.semanticweb.org/pat_c/ontologies/2026/5/untitled-ontology-12#hasVolume
:hasVolume rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf owl:topObjectProperty ;
           rdfs:domain :Container .


