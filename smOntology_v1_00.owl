                          :Has_Parameter_Measure :Volume, :Density ;
                          :Has_Result_Measure :Mass .

:Volume_From_Mass_Density rdf:type owl:NamedIndividual, :Derivation_Formula ;
                          rdfs:label "Volume From Mass Density" ;
